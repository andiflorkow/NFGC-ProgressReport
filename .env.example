# SMTP settings used by report send and test email routes.
# Copy this file to .env.local and fill in real values.

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@yourgym.com
SMTP_PASS=your-password-or-app-password
SMTP_FROM="NFGC Reports <your-email@yourgym.com>"
